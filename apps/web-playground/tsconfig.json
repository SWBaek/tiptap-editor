{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist-types",
    "tsBuildInfoFile": "dist-types/.tsbuildinfo"
  },
  "references": [
    { "path": "../../packages/sdoc-schema" },
    { "path": "../../packages/sdoc-format" },
    { "path": "../../packages/sdoc-diff" },
    { "path": "../../packages/sdoc-export" },
    { "path": "../../packages/editor-tiptap" }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
